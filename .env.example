# Thông tin Zalo Pay - Thay bằng thông tin thực của bạn!
ZALOPAY_APP_ID=12345
ZALOPAY_KEY1=your_key1
ZALOPAY_KEY2=your_key2

# Server config
PORT=8081
NODE_ENV=development

# Địa chỉ callback
RETURN_URL=http://localhost:8081/checkout.html
NOTIFY_URL=http://localhost:8081/api/zalopay-webhook

# API Endpoints
ZALOPAY_ENDPOINT_TEST=https://sandbox.zalopay.vn
ZALOPAY_ENDPOINT_PROD=https://api.zalopay.vn

# ── PostgreSQL (Admin Panel) ───────────────────────────────
PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=your_pg_password
PG_DATABASE=thehill_db

# ── Admin credentials ──────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_JWT_SECRET=change-this-to-a-long-random-secret
